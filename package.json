{
  "name": "panemar-morarit-si-panificatie-srl-nodejs-scraper",
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js scraper for PANEMAR MORARIT SI PANIFICATIE SRL jobs (peviitor.ro)",
  "main": "index.js",
  "scripts": {
    "scrape": "node --no-deprecation index.js",
    "test": "node --no-deprecation --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --no-deprecation --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.5.0",
    "dotenv": "^16.4.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/?(*.)+(test).js"],
    "verbose": true,
    "reporters": ["default", "jest-html-reporter"],
    "testTimeout": 30000
  }
}
